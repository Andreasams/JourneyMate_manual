# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings.delete 'IPHONEOS_DEPLOYMENT_TARGET'

      # Enable permission_handler location permissions
      # Required for iOS to show location permission dialog
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_LOCATION=1',
      ]
    end

    # Fix for PrivacyInfo.xcprivacy files in Xcode 15+
    # Ensures .xcprivacy files are copied as resources, not compiled
    # Required for map_launcher and other plugins with privacy manifests
    xcprivacy_files = []
    target.build_phases.each do |build_phase|
      # Remove .xcprivacy files from compilation (shouldn't be there, but clean up if present)
      if build_phase.is_a?(Xcodeproj::Project::Object::PBXSourcesBuildPhase)
        build_phase.files.delete_if do |build_file|
          if build_file.file_ref.path&.end_with?('PrivacyInfo.xcprivacy')
            xcprivacy_files << build_file.file_ref
            true
          else
            false
          end
        end
      end
    end

    # Add .xcprivacy files to "Copy Bundle Resources" build phase
    unless xcprivacy_files.empty?
      resources_build_phase = target.build_phases.find do |bp|
        bp.is_a?(Xcodeproj::Project::Object::PBXResourcesBuildPhase)
      end

      if resources_build_phase
        xcprivacy_files.each do |file_ref|
          # Only add if not already present
          unless resources_build_phase.files.any? { |f| f.file_ref == file_ref }
            resources_build_phase.add_file_reference(file_ref)
          end
        end
      end
    end
  end
end
